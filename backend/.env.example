NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
DATABASE_URL=postgresql://replace-with-user:replace-with-password@localhost:5432/exam_platform?schema=public
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=false
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
BCRYPT_ROUNDS=12
FILE_STORAGE_PATH=/app/storage
SEED_ADMIN_PASSWORD=replace-with-initial-admin-password
SEED_TEST_ADMIN_PASSWORD=replace-with-test-admin-password
SEED_TEST_STUDENT_PASSWORD=replace-with-test-student-password

