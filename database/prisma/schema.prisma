generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  INVITED
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum RoleCode {
  ADMIN
  REVIEWER
  STUDENT
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_TEXT
  ESSAY
  FILE_UPLOAD
}

enum QuestionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExamVersionStatus {
  PUBLISHED
  RETIRED
}

enum ResultVisibility {
  HIDDEN
  IMMEDIATE
  AFTER_REVIEW
  AFTER_CLOSE_DATE
}

enum AssignmentStatus {
  ASSIGNED
  REVOKED
  COMPLETED
  EXPIRED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
  GRADED
  CANCELLED
}

enum AnswerReviewStatus {
  NOT_REQUIRED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ResultStatus {
  PENDING_REVIEW
  READY
  PUBLISHED
  WITHHELD
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @db.VarChar(254)
  emailNormalized String     @unique @map("email_normalized") @db.VarChar(254)
  passwordHash    String?    @map("password_hash") @db.VarChar(255)
  firstName       String?    @map("first_name") @db.VarChar(100)
  lastName        String?    @map("last_name") @db.VarChar(100)
  status          UserStatus @default(INVITED)
  lastLoginAt     DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?  @map("deleted_at") @db.Timestamptz(6)
  createdById     String?    @map("created_by_id") @db.Uuid

  createdBy              User?                @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers           User[]               @relation("UserCreatedBy")
  roles                  UserRole[]
  roleAssignmentsCreated UserRole[]           @relation("UserRoleAssignedBy")
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  questionsCreated       Question[]           @relation("QuestionCreatedBy")
  questionsUpdated       Question[]           @relation("QuestionUpdatedBy")
  examsCreated           Exam[]               @relation("ExamCreatedBy")
  examsUpdated           Exam[]               @relation("ExamUpdatedBy")
  examVersionsPublished  ExamVersion[]        @relation("ExamVersionPublishedBy")
  assignments            ExamAssignment[]     @relation("ExamAssignmentUser")
  assignmentsCreated     ExamAssignment[]     @relation("ExamAssignmentAssignedBy")
  attempts               ExamAttempt[]        @relation("ExamAttemptUser")
  answersReviewed        AttemptAnswer[]      @relation("AnswerReviewedBy")
  results                Result[]             @relation("ResultUser")
  files                  FileAsset[]          @relation("FileOwner")
  auditLogs              AuditLog[]           @relation("AuditActor")

  @@index([status])
  @@index([createdById])
  @@index([createdAt])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        RoleCode @unique
  name        String   @db.VarChar(80)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users UserRole[]

  @@map("roles")
}

model UserRole {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  assignedById String?  @map("assigned_by_id") @db.Uuid
  assignedAt   DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("UserRoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@index([roleId])
  @@index([assignedById])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  ipAddress String?   @map("ip_address") @db.Inet
  userAgent String?   @map("user_agent") @db.VarChar(512)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(80)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  questions QuestionTag[]

  @@index([name])
  @@map("tags")
}

model Question {
  id                 String         @id @default(uuid()) @db.Uuid
  type               QuestionType
  status             QuestionStatus @default(DRAFT)
  prompt             String         @db.Text
  explanation        String?        @db.Text
  defaultPoints      Decimal        @default(1.0) @map("default_points") @db.Decimal(8, 2)
  difficulty         Int?
  allowPartialCredit Boolean        @default(false) @map("allow_partial_credit")
  metadata           Json?
  createdById        String?        @map("created_by_id") @db.Uuid
  updatedById        String?        @map("updated_by_id") @db.Uuid
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt         DateTime?      @map("archived_at") @db.Timestamptz(6)

  createdBy        User?                 @relation("QuestionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?                 @relation("QuestionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  options          QuestionOption[]
  tags             QuestionTag[]
  examQuestions    ExamQuestion[]
  versionQuestions ExamVersionQuestion[]

  @@index([type, status])
  @@index([status])
  @@index([createdById])
  @@index([updatedById])
  @@map("questions")
}

model QuestionOption {
  id          String   @id @default(uuid()) @db.Uuid
  questionId  String   @map("question_id") @db.Uuid
  label       String?  @db.VarChar(10)
  text        String   @db.Text
  isCorrect   Boolean  @default(false) @map("is_correct")
  sortOrder   Int      @map("sort_order")
  scoreWeight Decimal? @map("score_weight") @db.Decimal(5, 2)
  feedback    String?  @db.Text
  metadata    Json?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, sortOrder])
  @@index([questionId, isCorrect])
  @@map("question_options")
}

model QuestionTag {
  questionId String @map("question_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@index([tagId])
  @@map("question_tags")
}

model Exam {
  id                 String           @id @default(uuid()) @db.Uuid
  title              String           @db.VarChar(200)
  slug               String           @unique @db.VarChar(220)
  description        String?          @db.Text
  status             ExamStatus       @default(DRAFT)
  instructions       String?          @db.Text
  timeLimitMinutes   Int?             @map("time_limit_minutes")
  passingScore       Decimal?         @map("passing_score") @db.Decimal(5, 2)
  maxAttempts        Int              @default(1) @map("max_attempts")
  randomizeQuestions Boolean          @default(false) @map("randomize_questions")
  randomizeOptions   Boolean          @default(false) @map("randomize_options")
  resultVisibility   ResultVisibility @default(AFTER_REVIEW) @map("result_visibility")
  availableFrom      DateTime?        @map("available_from") @db.Timestamptz(6)
  availableUntil     DateTime?        @map("available_until") @db.Timestamptz(6)
  createdById        String?          @map("created_by_id") @db.Uuid
  updatedById        String?          @map("updated_by_id") @db.Uuid
  publishedAt        DateTime?        @map("published_at") @db.Timestamptz(6)
  archivedAt         DateTime?        @map("archived_at") @db.Timestamptz(6)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy   User?            @relation("ExamCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?            @relation("ExamUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sections    ExamSection[]
  questions   ExamQuestion[]
  versions    ExamVersion[]
  assignments ExamAssignment[]

  @@index([status])
  @@index([createdById])
  @@index([updatedById])
  @@index([availableFrom, availableUntil])
  @@map("exams")
}

model ExamSection {
  id                 String   @id @default(uuid()) @db.Uuid
  examId             String   @map("exam_id") @db.Uuid
  title              String   @db.VarChar(160)
  description        String?  @db.Text
  sortOrder          Int      @map("sort_order")
  randomizeQuestions Boolean  @default(false) @map("randomize_questions")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  exam            Exam                 @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions       ExamQuestion[]
  versionSections ExamVersionSection[]

  @@unique([examId, sortOrder])
  @@index([examId])
  @@map("exam_sections")
}

model ExamQuestion {
  id         String   @id @default(uuid()) @db.Uuid
  examId     String   @map("exam_id") @db.Uuid
  sectionId  String?  @map("section_id") @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  sortOrder  Int      @map("sort_order")
  points     Decimal  @db.Decimal(8, 2)
  isRequired Boolean  @default(true) @map("is_required")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  exam     Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  section  ExamSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  question Question     @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([examId, questionId])
  @@unique([examId, sectionId, sortOrder])
  @@index([questionId])
  @@index([sectionId])
  @@map("exam_questions")
}

model ExamVersion {
  id                 String            @id @default(uuid()) @db.Uuid
  examId             String            @map("exam_id") @db.Uuid
  versionNumber      Int               @map("version_number")
  status             ExamVersionStatus @default(PUBLISHED)
  title              String            @db.VarChar(200)
  description        String?           @db.Text
  instructions       String?           @db.Text
  timeLimitMinutes   Int?              @map("time_limit_minutes")
  passingScore       Decimal?          @map("passing_score") @db.Decimal(5, 2)
  maxAttempts        Int               @map("max_attempts")
  randomizeQuestions Boolean           @map("randomize_questions")
  randomizeOptions   Boolean           @map("randomize_options")
  resultVisibility   ResultVisibility  @map("result_visibility")
  publishedById      String?           @map("published_by_id") @db.Uuid
  publishedAt        DateTime          @default(now()) @map("published_at") @db.Timestamptz(6)
  retiredAt          DateTime?         @map("retired_at") @db.Timestamptz(6)

  exam        Exam                 @relation(fields: [examId], references: [id], onDelete: Restrict)
  publishedBy User?                @relation("ExamVersionPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  sections    ExamVersionSection[]
  questions   ExamVersionQuestion[]
  assignments ExamAssignment[]
  attempts    ExamAttempt[]
  results     Result[]

  @@unique([examId, versionNumber])
  @@index([status])
  @@index([publishedById])
  @@index([publishedAt])
  @@map("exam_versions")
}

model ExamVersionSection {
  id                 String   @id @default(uuid()) @db.Uuid
  examVersionId      String   @map("exam_version_id") @db.Uuid
  sourceSectionId    String?  @map("source_section_id") @db.Uuid
  title              String   @db.VarChar(160)
  description        String?  @db.Text
  sortOrder          Int      @map("sort_order")
  randomizeQuestions Boolean  @map("randomize_questions")

  examVersion   ExamVersion           @relation(fields: [examVersionId], references: [id], onDelete: Cascade)
  sourceSection ExamSection?          @relation(fields: [sourceSectionId], references: [id], onDelete: SetNull)
  questions     ExamVersionQuestion[]

  @@unique([examVersionId, sortOrder])
  @@index([sourceSectionId])
  @@map("exam_version_sections")
}

model ExamVersionQuestion {
  id                   String       @id @default(uuid()) @db.Uuid
  examVersionId        String       @map("exam_version_id") @db.Uuid
  examVersionSectionId String?      @map("exam_version_section_id") @db.Uuid
  sourceQuestionId     String?      @map("source_question_id") @db.Uuid
  type                 QuestionType
  prompt               String       @db.Text
  explanation          String?      @db.Text
  optionsSnapshot      Json?        @map("options_snapshot")
  correctAnswerSnapshot Json?       @map("correct_answer_snapshot")
  sortOrder            Int          @map("sort_order")
  points               Decimal      @db.Decimal(8, 2)
  isRequired           Boolean      @map("is_required")
  allowPartialCredit   Boolean      @map("allow_partial_credit")
  metadata             Json?

  examVersion        ExamVersion         @relation(fields: [examVersionId], references: [id], onDelete: Cascade)
  examVersionSection ExamVersionSection? @relation(fields: [examVersionSectionId], references: [id], onDelete: SetNull)
  sourceQuestion     Question?           @relation(fields: [sourceQuestionId], references: [id], onDelete: SetNull)
  answers            AttemptAnswer[]

  @@unique([examVersionId, examVersionSectionId, sortOrder])
  @@index([sourceQuestionId])
  @@index([examVersionSectionId])
  @@map("exam_version_questions")
}

model ExamAssignment {
  id                  String           @id @default(uuid()) @db.Uuid
  examId              String           @map("exam_id") @db.Uuid
  examVersionId       String           @map("exam_version_id") @db.Uuid
  userId              String           @map("user_id") @db.Uuid
  assignedById        String?          @map("assigned_by_id") @db.Uuid
  status              AssignmentStatus @default(ASSIGNED)
  startsAt            DateTime?        @map("starts_at") @db.Timestamptz(6)
  dueAt               DateTime?        @map("due_at") @db.Timestamptz(6)
  maxAttemptsOverride Int?             @map("max_attempts_override")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt           DateTime?        @map("revoked_at") @db.Timestamptz(6)
  completedAt         DateTime?        @map("completed_at") @db.Timestamptz(6)

  exam        Exam        @relation(fields: [examId], references: [id], onDelete: Restrict)
  examVersion ExamVersion @relation(fields: [examVersionId], references: [id], onDelete: Restrict)
  user        User        @relation("ExamAssignmentUser", fields: [userId], references: [id], onDelete: Restrict)
  assignedBy  User?       @relation("ExamAssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  attempts    ExamAttempt[]

  @@index([userId, status])
  @@index([examVersionId, status])
  @@index([assignedById])
  @@index([startsAt, dueAt])
  @@map("exam_assignments")
}

model ExamAttempt {
  id               String        @id @default(uuid()) @db.Uuid
  assignmentId     String        @map("assignment_id") @db.Uuid
  examVersionId    String        @map("exam_version_id") @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  attemptNumber    Int           @map("attempt_number")
  status           AttemptStatus @default(IN_PROGRESS)
  startedAt        DateTime      @default(now()) @map("started_at") @db.Timestamptz(6)
  expiresAt        DateTime?     @map("expires_at") @db.Timestamptz(6)
  lastActivityAt   DateTime?     @map("last_activity_at") @db.Timestamptz(6)
  submittedAt      DateTime?     @map("submitted_at") @db.Timestamptz(6)
  gradedAt         DateTime?     @map("graded_at") @db.Timestamptz(6)
  timeLimitMinutes Int?          @map("time_limit_minutes")
  score            Decimal?      @db.Decimal(8, 2)
  maxScore         Decimal       @default(0.0) @map("max_score") @db.Decimal(8, 2)
  passed           Boolean?
  ipAddress        String?       @map("ip_address") @db.Inet
  userAgent        String?       @map("user_agent") @db.VarChar(512)
  metadata         Json?

  assignment  ExamAssignment @relation(fields: [assignmentId], references: [id], onDelete: Restrict)
  examVersion ExamVersion    @relation(fields: [examVersionId], references: [id], onDelete: Restrict)
  user        User           @relation("ExamAttemptUser", fields: [userId], references: [id], onDelete: Restrict)
  answers     AttemptAnswer[]
  result      Result?

  @@unique([assignmentId, attemptNumber])
  @@index([userId, status])
  @@index([examVersionId, status])
  @@index([startedAt])
  @@map("exam_attempts")
}

model AttemptAnswer {
  id                    String             @id @default(uuid()) @db.Uuid
  attemptId             String             @map("attempt_id") @db.Uuid
  examVersionQuestionId String             @map("exam_version_question_id") @db.Uuid
  answerText            String?            @map("answer_text") @db.Text
  selectedOptionIds     Json?              @map("selected_option_ids")
  fileAssetId           String?            @map("file_asset_id") @db.Uuid
  score                 Decimal?           @db.Decimal(8, 2)
  isCorrect             Boolean?           @map("is_correct")
  reviewStatus          AnswerReviewStatus @default(NOT_REQUIRED) @map("review_status")
  reviewedById          String?            @map("reviewed_by_id") @db.Uuid
  reviewedAt            DateTime?          @map("reviewed_at") @db.Timestamptz(6)
  feedback              String?            @db.Text
  savedAt               DateTime           @default(now()) @map("saved_at") @db.Timestamptz(6)
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  attempt             ExamAttempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  examVersionQuestion ExamVersionQuestion @relation(fields: [examVersionQuestionId], references: [id], onDelete: Restrict)
  fileAsset           FileAsset?          @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)
  reviewedBy          User?               @relation("AnswerReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([attemptId, examVersionQuestionId])
  @@index([examVersionQuestionId])
  @@index([fileAssetId])
  @@index([reviewStatus])
  @@index([reviewedById])
  @@map("attempt_answers")
}

model Result {
  id            String       @id @default(uuid()) @db.Uuid
  attemptId     String       @unique @map("attempt_id") @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  examVersionId String       @map("exam_version_id") @db.Uuid
  status        ResultStatus @default(PENDING_REVIEW)
  score         Decimal      @db.Decimal(8, 2)
  maxScore      Decimal      @map("max_score") @db.Decimal(8, 2)
  percentage    Decimal      @db.Decimal(5, 2)
  passed        Boolean
  autoScore     Decimal?     @map("auto_score") @db.Decimal(8, 2)
  manualScore   Decimal?     @map("manual_score") @db.Decimal(8, 2)
  publishedAt   DateTime?    @map("published_at") @db.Timestamptz(6)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  attempt     ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user        User        @relation("ResultUser", fields: [userId], references: [id], onDelete: Restrict)
  examVersion ExamVersion @relation(fields: [examVersionId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([examVersionId, status])
  @@index([publishedAt])
  @@map("results")
}

model FileAsset {
  id           String    @id @default(uuid()) @db.Uuid
  ownerUserId  String    @map("owner_user_id") @db.Uuid
  bucket       String    @db.VarChar(120)
  storageKey   String    @unique @map("storage_key") @db.VarChar(500)
  originalName String    @map("original_name") @db.VarChar(255)
  mimeType     String    @map("mime_type") @db.VarChar(120)
  sizeBytes    BigInt    @map("size_bytes")
  checksum     String?   @db.VarChar(128)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  owner   User            @relation("FileOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  answers AttemptAnswer[]

  @@index([ownerUserId])
  @@index([createdAt])
  @@map("file_assets")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(120)
  entityType  String   @map("entity_type") @db.VarChar(120)
  entityId    String?  @map("entity_id") @db.Uuid
  ipAddress   String?  @map("ip_address") @db.Inet
  userAgent   String?  @map("user_agent") @db.VarChar(512)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
