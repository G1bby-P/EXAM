# Production environment for a public web deployment.
# Copy this file to .env.production and replace every example value before going live.

POSTGRES_DB=exam_platform
POSTGRES_USER=exam_platform
# Use URL-safe characters because docker-compose builds DATABASE_URL from this value.
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

JWT_ACCESS_SECRET=replace-with-at-least-64-random-characters
JWT_REFRESH_SECRET=replace-with-another-64-random-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30
BCRYPT_ROUNDS=12

# Seed credentials are only for validation/staging. Replace these values before running api-seed.
# The app will create/update:
# - admin@exam.local with SEED_ADMIN_PASSWORD
# - admin@test.com with SEED_TEST_ADMIN_PASSWORD
# - alumno@test.com with SEED_TEST_STUDENT_PASSWORD
SEED_ADMIN_PASSWORD=replace-with-initial-admin-password
SEED_TEST_ADMIN_PASSWORD=replace-with-test-admin-password
SEED_TEST_STUDENT_PASSWORD=replace-with-test-student-password

API_PREFIX=api/v1
SWAGGER_ENABLED=false
SWAGGER_PATH=docs

# Replace these hosts with real DNS records pointing to the public server IP.
ADMIN_HOST=admin.example.com
STUDENT_HOST=alumno.example.com
API_HOST=api.example.com
CERT_NAME=admin.example.com

HTTP_PORT=80
HTTPS_PORT=443
CLIENT_MAX_BODY_SIZE=20m
NEXT_PUBLIC_API_BASE_URL=/api/v1
CORS_ORIGINS=https://admin.example.com,https://alumno.example.com,https://api.example.com

# Let's Encrypt.
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_STAGING=1
CERTBOT_FORCE_RENEWAL=0
ALLOW_INSECURE_HTTPS=0

# Logs and backups.
LOG_MAX_SIZE=10m
LOG_MAX_FILE=5
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400

# Optional monitoring stack. Bind to localhost by default and expose through SSH tunnel or VPN.
PROMETHEUS_BIND=127.0.0.1:9090
GRAFANA_BIND=127.0.0.1:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-grafana-password
